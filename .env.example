# PostgreSQL connection. Local dev runs Postgres in Docker on port 5433
# (see README). In production point this at Neon / managed Postgres.
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/novidms?schema=public"

# Secret used to sign session cookies. Generate one with:
#   openssl rand -base64 32
AUTH_SECRET=""

# Storage provider for uploaded files:
#   "disk" — local filesystem (development)
#   "blob" — Vercel Blob (production on Vercel)
STORAGE_PROVIDER="disk"
# Local disk provider: directory where files are stored (dev only).
STORAGE_DIR="./uploads"
# Vercel Blob (when STORAGE_PROVIDER="blob"): on Vercel this token is added
# automatically when you create a Blob store — no need to set it by hand.
# BLOB_READ_WRITE_TOKEN=""

# Tesseract.js languages for image OCR (e.g. "hrv+eng").
OCR_LANGS="hrv+eng"

# Public base URL of the app (the Vercel URL in production).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Email sending (Resend) — used to email user invitations. Without RESEND_API_KEY
# invites still work: the UI shows a copyable link instead. With it, invites are
# emailed automatically.
# RESEND_API_KEY=""
# From address. Must be on a domain verified in Resend (e.g. noreply@docorex.com).
# Until a domain is verified you can use Resend's shared "onboarding@resend.dev".
# EMAIL_FROM="Docorex <noreply@docorex.com>"

# Contact email shown in the trial / restricted-access banner.
# NEXT_PUBLIC_SUPPORT_EMAIL="info@docorex.com"

# Anthropic API key — used for AI invoice-field extraction AND as the OCR fallback
# for scanned PDFs / unreadable images (local OCR runs first; AI only when it fails).
# Optional: without it, local OCR still works and AI features simply no-op.
# ANTHROPIC_API_KEY=""
# Model for invoice-field extraction. Default claude-opus-4-8; cheaper/faster at volume:
# ANTHROPIC_MODEL="claude-haiku-4-5"
# Model for AI vision OCR of scans. Defaults to fast/cheap claude-haiku-4-5.
# ANTHROPIC_OCR_MODEL="claude-haiku-4-5"
