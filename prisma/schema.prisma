// NOVIDMS schema (PostgreSQL).
//
// Set DATABASE_URL to your Postgres connection string. Run `npm run db:migrate`
// to apply migrations (base schema + the raw-SQL full-text search migrations).
//
// Tenant isolation rule: every query that reads documents, categories, cost
// centers or users MUST filter by the logged-in user's tenantId. See
// src/lib/tenant.ts.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id           String       @id @default(cuid())
  name         String
  plan         Plan         @default(BASIC)
  // Lifecycle: new self-service firms start as TRIAL with a trialEndsAt 30 days
  // out. When the trial expires (or status is SUSPENDED) write actions are
  // blocked; reads stay open. The platform owner flips status from /owner.
  status       TenantStatus @default(TRIAL)
  trialEndsAt  DateTime?
  // Email admine kad netko doda novi dokument (uključeno po defaultu).
  notifyNewDocument Boolean  @default(true)
  // Email admine par dana prije isteka probnog razdoblja (uključeno po defaultu).
  notifyTrialExpiry Boolean  @default(true)
  // Kad je poslan podsjetnik o isteku triala (sprječava dnevno ponavljanje).
  trialReminderSentAt DateTime?
  createdAt    DateTime     @default(now())
  users        User[]
  documents    Document[]
  categories   Category[]
  costCenters  CostCenter[]
  templates    DocumentTemplate[]
  workflows    WorkflowDefinition[]
}

// Admin-defined approval process: an ordered list of step labels. Who approves
// each step is chosen by the user when they start the workflow on a document.
model WorkflowDefinition {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  name        String
  description String?
  // Uređeni niz koraka (oznake), npr. ["Voditelj odjela","Direktor"] (JSON).
  steps       Json     @default("[]")
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
}

model DocumentTemplate {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  name        String
  description String?
  body        String   @db.Text
  // Polja koja korisnik popunjava: [{ key, label, type, required }] (JSON).
  fields      Json     @default("[]")
  // "TEXT" = portal editor (body → PDF) · "DOCX" = uploani Word (fileKey → DOCX).
  kind        String   @default("TEXT")
  fileKey     String?
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
}

model User {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  email         String    @unique
  name          String
  password      String // hash (scrypt)
  role          Role      @default(MEMBER)
  // Platform owner (super-admin) flag: grants access to the cross-tenant /owner
  // back-office. NOT tenant-scoped — the only role that may read across firms.
  platformAdmin Boolean   @default(false)
  invitedAt     DateTime?
  acceptedAt    DateTime?
  createdAt     DateTime  @default(now())

  @@index([tenantId])
}

model Document {
  id           String      @id @default(cuid())
  tenantId     String
  tenant       Tenant      @relation(fields: [tenantId], references: [id])
  title        String
  description  String?
  fileKey      String // key in storage
  mimeType     String
  sizeBytes    Int
  ocrText      String?     @db.Text
  ocrStatus    OcrStatus   @default(PENDING)
  categoryId   String?
  category     Category?   @relation(fields: [categoryId], references: [id])
  costCenterId String?
  costCenter   CostCenter? @relation(fields: [costCenterId], references: [id])
  partner       String?
  documentDate  DateTime?
  amount        Decimal?    @db.Decimal(12, 2)
  invoiceNumber String?
  dueDate       DateTime?
  uploadedById  String
  createdAt     DateTime    @default(now())

  /// Full-text search vector, created by the add_fts_tsvector raw SQL migration
  /// as a STORED generated column. Declared Unsupported so Prisma tracks it
  /// without managing its generated expression.
  searchVector Unsupported("tsvector")?

  @@index([tenantId])
  @@index([tenantId, categoryId])
  @@index([tenantId, costCenterId])
  @@index([searchVector], type: Gin)
}

model Category {
  id        String     @id @default(cuid())
  tenantId  String
  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  name      String
  documents Document[]

  @@index([tenantId])
}

/// Faza 2: a cost center (e.g. an apartment / property) that documents are
/// grouped under, so all invoices for one center can be listed and totalled.
model CostCenter {
  id        String     @id @default(cuid())
  tenantId  String
  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  name      String
  code      String?
  documents Document[]
  createdAt DateTime   @default(now())

  @@index([tenantId])
}

model AuditEntry {
  id         String   @id @default(cuid())
  tenantId   String
  documentId String?
  userId     String
  action     String // "UPLOAD" | "VIEW" | "DOWNLOAD" | "DELETE"
  createdAt  DateTime @default(now())

  @@index([tenantId, documentId])
}

enum Plan {
  BASIC
  BUSINESS
  PROFESSIONAL
}

enum TenantStatus {
  TRIAL
  ACTIVE
  SUSPENDED
}

enum Role {
  ADMIN
  MEMBER
}

enum OcrStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}
